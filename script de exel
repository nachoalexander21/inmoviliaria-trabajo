function crearBaseDeDatos() {

  const ss =
  SpreadsheetApp.getActiveSpreadsheet();

  let hoja =
  ss.getSheetByName("Reservas");

  if(!hoja){

    hoja =
    ss.insertSheet("Reservas");

  }

  hoja.clear();

  const encabezados = [[

    "ID",
    "Nombre",
    "Email",
    "Telefono",
    "Fecha",
    "Hora",
    "Propiedad",
    "Mensaje",
    "FechaRegistro",
    "WhatsApp"

  ]];

  hoja.getRange(1,1,1,10)
  .setValues(encabezados);

  hoja.getRange(1,1,1,10)
  .setBackground("#0f766e")
  .setFontColor("white")
  .setFontWeight("bold");

  hoja.setFrozenRows(1);

}



